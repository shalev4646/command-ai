.env
venv/
__pycache__/
*.pyc
storage/chroma_db/
storage/metrics_log.jsonl
# generated by _check_updates.py on every run — the baseline
# (storage/order_watch.json) IS committed, the report is not
storage/order_watch_report.md
.streamlit/secrets.toml
# runtime mirror of pdf-ldf_law for static serving — only the placeholder
# is committed, so the folder exists when the server boots and mounts /static
static/*
!static/.gitkeep
New Text Document.txt
.claude/

# Design/handoff artifacts — mockups & zips dropped in for reference, not
# source. Ignoring them also stops push.bat's `git add .` from sweeping them
# into a commit (has happened before). No source .html/.zip lives in the repo
# (only new_desing.zip, already tracked).
docs/
*.zip
*.html
